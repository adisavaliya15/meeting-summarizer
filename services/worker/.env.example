SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Use Supabase Pooler (IPv4-friendly). URL-encode password special chars.
# Example username format is often: postgres.<project-ref>
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-your-region.pooler.supabase.com:6543/postgres
OLLAMA_URL=http://localhost:11434
WHISPER_MODEL=large-v3
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SEC=1500
POLL_INTERVAL_SEC=5
MAX_ATTEMPTS=3
WORKER_ID=laptop-worker-1
