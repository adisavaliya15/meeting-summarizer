# Optional: override compose env_file target (default: .env.docker)
APP_ENV_FILE=.env.docker

# Shared app settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# IMPORTANT:
# 1) URL-encode password special chars in this URL.
# 2) In Docker Compose env files, a literal '$' must be escaped as '$$'
#    (otherwise Compose treats it as variable interpolation).
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-your-region.pooler.supabase.com:6543/postgres

# API settings
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
API_WORKERS=2

# Worker + summarization settings
# If running `docker compose --profile ollama`, keep this as http://ollama:11434
# If using external Ollama, change to that endpoint.
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
WHISPER_MODEL=large-v3
POLL_INTERVAL_SEC=5
MAX_ATTEMPTS=3
WORKER_ID=docker-worker-1

# Frontend build-time settings
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
